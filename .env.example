# Supabase (requerido para auth y sincronización en la nube)
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# Groq API (requerido para DevBot AI)
PUBLIC_GROQ_API_KEY=

# Media APIs - Regístrate en cada servicio para obtener tus keys:
# TMDB: https://www.themoviedb.org/settings/api
# RAWG: https://rawg.io/apidocs
# Last.fm: https://www.last.fm/api/account/create
PUBLIC_TMDB_API_KEY=
PUBLIC_LASTFM_API_KEY=

# Twitch/IGDB (videojuegos) - https://dev.twitch.tv/console/apps
PUBLIC_TWITCH_CLIENT_ID=
PUBLIC_TWITCH_CLIENT_SECRET=
